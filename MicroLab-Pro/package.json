{
  "name": "microlab-pro",
  "productName": "MicroLab-Pro",
  "version": "3.3.2",
  "type": "module",
  "description": "Offline-first Laboratory Information Management System",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:publish": "vite build && electron-builder --publish always",
    "rebuild-sqlite": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "better-sqlite3": "^9.4.0",
    "electron-updater": "^6.8.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.344.0",
    "node-machine-id": "^1.1.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.1",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.microlab.pro",
    "productName": "MicroLab Pro",
    "publish": [
      {
        "provider": "github",
        "owner": "rajatkkhairnar",
        "repo": "MicroLab_Portfolio",
        "private": true
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "src/assests/customer-behavior.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
