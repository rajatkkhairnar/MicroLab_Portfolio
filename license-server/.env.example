# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/microlab_licenses

# ─── Security ────────────────────────────────────────────────────────
# Random 64-char string for signing license JWTs
SIGNING_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# Shared API key bundled in the Electron app (random 32-char string)
API_KEY=CHANGE_ME_TO_RANDOM_32_CHAR_STRING

# ─── Admin Portal Credentials ────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ─── Server ──────────────────────────────────────────────────────────
PORT=3000

# ─── Email OTP (EmailJS) ─────────────────────────────────────────────
# Get these from your EmailJS dashboard: https://dashboard.emailjs.com
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
# Optional: Private key for server-side security (Account → API Keys)
# EMAILJS_PRIVATE_KEY=your_private_key
